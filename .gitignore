.coverage
htmlcov/

# ── Docker (volumes locaux) ───────────────────────────────────────────────────
postgres-data/
redis-data/

# ── Alembic (garder les migrations mais pas le cache) ────────────────────────
alembic/__pycache__/

# ── Node (si on compile Tailwind en prod) ─────────────────────────────────────
node_modules/

# ── Données runtime (à exclure) ───────────────────────────────────────────────
backups/
uploads/
